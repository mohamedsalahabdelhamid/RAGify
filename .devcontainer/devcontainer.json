{
  "name": "RAGify — AI Document Intelligence",
  "image": "mcr.microsoft.com/devcontainers/base:bullseye",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3000, 9999],
  "portsAttributes": {
    "3000": {
      "label": "🖥️ RAGify Frontend",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "9999": {
      "label": "⚙️ RAGify Backend API",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postCreateCommand": "cp .env.example .env && echo 'Add your API keys to the .env file, then run: docker compose up --build -d'",
  "postStartCommand": "[ -f .env ] && grep -q 'your_gemini_api_key_here' .env || docker compose up --build -d",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
